<UserControl x:Class="Takt.Fluent.Views.Logistics.Visitors.VisitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Takt.Fluent.Controls"
             xmlns:local="clr-namespace:Takt.Fluent.Localization"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1280">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="300" MinHeight="200" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="200" />
        </Grid.RowDefinitions>

        <!-- 主表：访客 -->
        <controls:TaktDataGrid Grid.Row="0"
                                x:Name="VisitorDataGrid"
                                ItemsSource="{Binding Visitors}"
                                SelectedItem="{Binding SelectedVisitor, Mode=TwoWay}"
                                QueryKeyword="{Binding VisitorKeyword, Mode=TwoWay}"
                                QueryPlaceholder="{local:Loc Key=common.placeholder.keywordHint, Param0Key=Logistics.Visitors.Visitor.Keyword}"
                                ShowToolbarCreate="True"
                                ShowToolbarUpdate="True"
                                ShowToolbarDelete="True"
                                ShowToolbarImport="True"
                                ShowToolbarExport="True"
                                CreateCommand="{Binding CreateVisitorCommand}"
                                UpdateCommand="{Binding UpdateVisitorCommand}"
                                DeleteCommand="{Binding DeleteVisitorCommand}"
                                ImportCommand="{Binding ImportCommand}"
                                ExportCommand="{Binding ExportCommand}"
                                DownloadTemplateCommand="{Binding DownloadTemplateCommand}"
                                RowUpdateCommand="{Binding UpdateVisitorCommand}"
                                RowDeleteCommand="{Binding DeleteVisitorCommand}"
                                PageIndex="{Binding VisitorPageIndex, Mode=TwoWay}"
                                PageSize="{Binding VisitorPageSize, Mode=TwoWay}"
                                TotalCount="{Binding VisitorTotalCount}"
                                QueryCommand="{Binding QueryVisitorsCommand}"
                                ResetCommand="{Binding ResetVisitorsCommand}"
                                PageChangedCommand="{Binding PageChangedVisitorsCommand}"
                                Loaded="VisitorDataGrid_Loaded">
            <controls:TaktDataGrid.Columns>
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.Visitors.Visitor.CompanyName}" BindingPath="CompanyName" Width="*" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.Visitors.Visitor.StartTime}" BindingPath="StartTime" Width="150" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.Visitors.Visitor.EndTime}" BindingPath="EndTime" Width="150" />
            </controls:TaktDataGrid.Columns>
        </controls:TaktDataGrid>

        <GridSplitter Grid.Row="1" Height="6" VerticalAlignment="Center" HorizontalAlignment="Stretch" />

        <!-- 子表：访客详情（支持行内编辑） -->
        <controls:TaktInlineEditDataGrid Grid.Row="2"
                                         x:Name="VisitorDetailDataGrid"
                                         ItemsSource="{Binding VisitorDetails}"
                                         SelectedItem="{Binding SelectedVisitorDetail, Mode=TwoWay}"
                                         EditingItem="{Binding EditingVisitorDetail, Mode=TwoWay}"
                                         ShowQueryArea="True"
                                         QueryKeyword="{Binding DetailKeyword, Mode=TwoWay}"
                                         QueryPlaceholder="{local:Loc Key=common.placeholder.keywordHint, Param0Key=Logistics.Visitors.VisitorDetail.Keyword}"
                                         QueryCommand="{Binding QueryDetailsCommand}"
                                         ResetCommand="{Binding ResetDetailsCommand}"
                                         ShowToolbar="True"
                                         ShowToolbarAddRow="True"
                                         AddRowCommand="{Binding CreateDetailInlineCommand}"
                                         RowUpdateCommand="{Binding UpdateDetailInlineCommand}"
                                         RowSaveCommand="{Binding SaveDetailInlineCommand}"
                                         RowCancelCommand="{Binding CancelDetailInlineCommand}"
                                         RowDeleteCommand="{Binding DeleteDetailCommand}"
                                         ShowRowUpdate="True"
                                         ShowRowSave="True"
                                         ShowRowCancel="True"
                                         ShowRowDelete="True"
                                         EmptyText="{local:Loc Key=common.noData}"
                                         Loaded="VisitorDetailDataGrid_Loaded">
            <controls:TaktInlineEditDataGrid.Columns>
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.Visitors.VisitorDetail.VisitorId}" BindingPath="VisitorId" Width="100" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.Visitors.VisitorDetail.Department}" BindingPath="Department" Width="150" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.Visitors.VisitorDetail.Name}" BindingPath="Name" Width="150" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.Visitors.VisitorDetail.Position}" BindingPath="Position" Width="150" />
            </controls:TaktInlineEditDataGrid.Columns>
        </controls:TaktInlineEditDataGrid>
    </Grid>
</UserControl>

